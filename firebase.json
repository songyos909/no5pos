{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "/api/**", "function": { "functionId": "api", "region": "asia-southeast1" } }]
  },
  "functions": [{ "source": "functions", "codebase": "default", "runtime": "nodejs20" }],
  "firestore": { "rules": "firestore.rules" }
}
